# WeChat Bridge 环境变量配置
# 复制本文件为 .env 并填写

# === 基础配置 ===
PORT=5200
TZ=Asia/Shanghai

# === Webhook 推送（可选）===
# 收到微信消息时主动 POST 到此地址（适用于 Dify/FastGPT/n8n/Node-RED）
WEBHOOK_URL=

# === API 鉴权（推荐）===
# 设置后所有 /api/* 接口需携带 Bearer Token
# ⚠️ 请勿提交真实 Token 到版本控制，建议通过 docker-compose env 或 CI Secret 注入
API_TOKEN=

# === AI 配置（可选，也可在 Web UI 中设置）===
AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
# ⚠️ 请勿提交真实 API Key 到版本控制
AI_API_KEY=

# === 数据持久化路径（一般无需修改）===
# TOKEN_FILE=/data/token.json
# CONTACTS_FILE=/data/contacts.json
# AI_CONFIG_FILE=/data/ai_config.json
# DB_FILE=/data/messages.db
# MEDIA_DIR=/data/media

# === 消息保留天数（默认 90 天自动清理）===
# MSG_RETENTION_DAYS=90
